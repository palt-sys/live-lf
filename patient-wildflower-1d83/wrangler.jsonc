{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "live-lf",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "durable_objects": {
    "bindings": [
      { "name": "OHLCV_DO", "class_name": "PollerDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PollerDO"] }
  ],
  "vars": {
    "ASSETS": "dxy,chf,eur,gbp,btc,eth,xrp,sol,xau,xag,aud,jpy,spx,nq,ym",
    "TF": "1",
    "CANDLES": "10000",
    "INTERVAL_MS": "10000",
    "GITHUB_OWNER": "palt-sys",
    "GITHUB_REPO": "live-lf",
    "GITHUB_PATH_PREFIX": "storage/livejson",
    "GITHUB_BRANCH": "main"
  }
}